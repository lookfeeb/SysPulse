{
  "name": "syspulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:helper": "powershell -ExecutionPolicy Bypass -File scripts/build-helper.ps1",
    "build:helper:ensure": "powershell -ExecutionPolicy Bypass -File scripts/ensure-helper.ps1",
    "tauri:dev": "npm run build:helper:ensure && tauri dev",
    "tauri:build": "npm run build:helper && tauri build"
  },
  "dependencies": {
