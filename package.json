    "i18next": "^26.0.0",
    "marked": "^18.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^6.30.0",
    "zustand": "^5.0.0"
  },
