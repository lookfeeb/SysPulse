{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the configuration window and overlay window",
  "windows": ["config", "overlay"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-start-dragging",
    "core:window:allow-current-monitor",
    "core:window:allow-close",
    "core:webview:default",
    "core:app:default",
    "core:menu:default",
    "core:tray:default",
    "core:path:default",
    "dialog:default",
    "opener:default",
    "updater:default"
  ]
}
